#
# Apache HTTP Server Configuration File
# Generated by Ansible Template on {{ ansible_date_time.iso8601 }}
# Managed by: {{ ansible_user }}@{{ ansible_hostname }}
#

# Basic server configuration
ServerRoot "/etc/httpd"
Listen {{ apache_listen_port }}
{% if enable_ssl %}
Listen {{ ssl_port }} ssl
{% endif %}

# Dynamic module loading based on host variables
{% if custom_modules is defined %}
{% for module in custom_modules %}
LoadModule {{ module }}_module modules/{{ module }}.so
{% endfor %}
{% endif %}

# User and Group
User apache
Group apache

# Server identification
ServerAdmin {{ apache_server_admin }}
ServerName {{ apache_server_name }}:{{ apache_port }}

# Document root and directory permissions
DocumentRoot "{{ apache_document_root }}"

<Directory "{{ apache_document_root }}">
    Options Indexes FollowSymLinks
    AllowOverride None
    Require all granted
</Directory>

# Performance tuning based on environment
{% if app_environment == 'production' %}
# Production settings
MaxRequestWorkers {{ apache_max_clients }}
ThreadsPerChild {{ apache_threads_per_child }}
Timeout {{ apache_timeout }}
KeepAlive On
MaxKeepAliveRequests 100
KeepAliveTimeout 15
{% else %}
# Development settings
MaxRequestWorkers {{ apache_max_clients }}
ThreadsPerChild 10
Timeout 60
KeepAlive Off
{% endif %}

# Logging configuration
ErrorLog "logs/error_log"
LogLevel {{ apache_log_level }}

# Custom log format with system information
LogFormat "%h %l %u %t \"%r\" %>s %O \"%{Referer}i\" \"%{User-Agent}i\" [{{ ansible_hostname }}]" combined
CustomLog "logs/access_log" combined

# Server signature with dynamic information
ServerTokens Prod
ServerSignature Off

# Application-specific configuration
<Directory "{{ apache_document_root }}/{{ app_name | lower | replace(' ', '_') }}">
    Options -Indexes +FollowSymLinks
    AllowOverride All
    Require all granted
    
    # Environment-specific headers
    {% if app_environment == 'production' %}
    Header always set X-Environment "Production"
    Header always set X-App-Version "{{ app_version }}"
    {% else %}
    Header always set X-Environment "Development"
    Header always set X-Debug "Enabled"
    {% endif %}
</Directory>

# System information comments (for debugging)
# System: {{ ansible_distribution }} {{ ansible_distribution_version }}
# Architecture: {{ ansible_architecture }}
# Processor: {{ ansible_processor[1] if ansible_processor|length > 1 else 'Unknown' }}
# Memory: {{ ansible_memtotal_mb }}MB
# Generated on: {{ ansible_date_time.date }} at {{ ansible_date_time.time }}

# Include additional configuration files
IncludeOptional conf.d/*.conf
EOF
